<UserControl x:Class="InfiniteScroll.Controls.TerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource TerminalBackgroundBrush}"
             GotFocus="OnGotFocus">

    <Grid>
        <RichTextBox x:Name="TerminalOutput"
                     IsReadOnly="True"
                     Background="{StaticResource TerminalBackgroundBrush}"
                     Foreground="{StaticResource TerminalForegroundBrush}"
                     FontFamily="Cascadia Mono, Consolas, Courier New"
                     FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                     BorderThickness="0"
                     Padding="8"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Disabled"
                     IsDocumentEnabled="False"
                     AcceptsReturn="False" />

        <!-- Input overlay at bottom -->
        <TextBox x:Name="TerminalInput"
                 VerticalAlignment="Bottom"
                 Background="#1A1A1F"
                 Foreground="{StaticResource TerminalForegroundBrush}"
                 CaretBrush="{StaticResource TerminalForegroundBrush}"
                 FontFamily="Cascadia Mono, Consolas, Courier New"
                 FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=UserControl}}"
                 BorderThickness="0,1,0,0"
                 BorderBrush="{StaticResource BorderBrush}"
                 Padding="8,4"
                 KeyDown="TerminalInput_KeyDown" />
    </Grid>
</UserControl>
