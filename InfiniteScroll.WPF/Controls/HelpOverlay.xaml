<UserControl x:Class="InfiniteScroll.Controls.HelpOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#88000000"
          MouseDown="Background_MouseDown">
        <Border Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Width="420"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="20" ShadowDepth="0" />
            </Border.Effect>

            <StackPanel>
                <!-- Header -->
                <DockPanel Margin="20,14">
                    <TextBlock Text="Keyboard Shortcuts"
                               FontFamily="Consolas"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <Button DockPanel.Dock="Right"
                            Style="{StaticResource IconButton}"
                            Click="CloseButton_Click"
                            HorizontalAlignment="Right">
                        <TextBlock Text="&#xE8BB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" />
                    </Button>
                </DockPanel>

                <Rectangle Height="1" Fill="{StaticResource BorderBrush}" />

                <!-- Shortcut list -->
                <ItemsControl x:Name="ShortcutList"
                              Margin="0,6">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DockPanel Margin="20,7">
                                <TextBlock Text="{Binding Key}"
                                           Width="120"
                                           TextAlignment="Right"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           FontWeight="Medium"
                                           Foreground="{StaticResource AccentBrush}"
                                           Margin="0,0,12,0" />
                                <TextBlock Text="{Binding Description}"
                                           FontFamily="Consolas"
                                           FontSize="13"
                                           Foreground="{StaticResource TextBrush}" />
                            </DockPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
