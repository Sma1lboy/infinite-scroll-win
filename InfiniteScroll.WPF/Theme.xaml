<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:converters="clr-namespace:InfiniteScroll.Converters">

    <!-- Converters -->
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

    <!-- Background colors matching Swift Theme.swift -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1A1A1F"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#212126"/>
    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#29292E"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#404047"/>
    <SolidColorBrush x:Key="TextBrush" Color="#D9D9E0"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8C8C94"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#6699FF"/>
    <SolidColorBrush x:Key="CloseButtonBrush" Color="#CC4D4D"/>
    <SolidColorBrush x:Key="AddButtonBrush" Color="#4DB34D"/>
    <SolidColorBrush x:Key="FocusBorderBrush" Color="#6699FF"/>

    <!-- Notes-specific -->
    <SolidColorBrush x:Key="NotesBackgroundBrush" Color="#1F1F24"/>
    <SolidColorBrush x:Key="NotesTextBrush" Color="#D9D9E0"/>

    <!-- Terminal colors -->
    <SolidColorBrush x:Key="TerminalBackgroundBrush" Color="#1A1A1F"/>
    <SolidColorBrush x:Key="TerminalForegroundBrush" Color="#D9D9E0"/>

    <!-- Dimensions -->
    <sys:Double x:Key="PanelHeight" xmlns:sys="clr-namespace:System;assembly=mscorlib">750</sys:Double>
    <sys:Double x:Key="HeaderHeight" xmlns:sys="clr-namespace:System;assembly=mscorlib">32</sys:Double>
    <sys:Double x:Key="PanelCornerRadius" xmlns:sys="clr-namespace:System;assembly=mscorlib">8</sys:Double>
    <sys:Double x:Key="PanelSpacing" xmlns:sys="clr-namespace:System;assembly=mscorlib">12</sys:Double>
    <CornerRadius x:Key="PanelCornerRadiusValue">8</CornerRadius>

    <!-- Scrollbar style (dark) -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
    </Style>

    <!-- Button style (borderless) -->
    <Style x:Key="IconButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Arrow"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#33FFFFFF"/>
            </Trigger>
        </Style.Triggers>
    </Style>

</ResourceDictionary>
