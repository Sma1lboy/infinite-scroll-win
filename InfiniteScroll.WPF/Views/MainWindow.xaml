<Window x:Class="InfiniteScroll.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:InfiniteScroll.Views"
        xmlns:controls="clr-namespace:InfiniteScroll.Controls"
        Title="Infinite Scroll"
        Width="1800" Height="900"
        MinWidth="1200" MinHeight="600"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow">

    <Window.InputBindings>
        <!-- Ctrl+W: Close current cell -->
        <KeyBinding Key="W" Modifiers="Ctrl" Command="{Binding CloseCurrentCellCommand}" />
        <!-- Ctrl+D: Duplicate current cell -->
        <KeyBinding Key="D" Modifiers="Ctrl" Command="{Binding DuplicateCurrentCellCommand}" />
        <!-- Ctrl+Shift+Down: New row below -->
        <KeyBinding Key="Down" Modifiers="Ctrl+Shift" Command="{Binding AddPanelCommand}" />
        <!-- Ctrl+=: Zoom in -->
        <KeyBinding Key="OemPlus" Modifiers="Ctrl" Command="{Binding ZoomInCommand}" />
        <!-- Ctrl+-: Zoom out -->
        <KeyBinding Key="OemMinus" Modifiers="Ctrl" Command="{Binding ZoomOutCommand}" />
        <!-- Ctrl+Up: Focus row above -->
        <KeyBinding Key="Up" Modifiers="Ctrl" Command="{Binding FocusUpCommand}" />
        <!-- Ctrl+Down: Focus row below -->
        <KeyBinding Key="Down" Modifiers="Ctrl" Command="{Binding FocusDownCommand}" />
        <!-- Ctrl+Left: Focus left -->
        <KeyBinding Key="Left" Modifiers="Ctrl" Command="{Binding FocusLeftCommand}" />
        <!-- Ctrl+Right: Focus right -->
        <KeyBinding Key="Right" Modifiers="Ctrl" Command="{Binding FocusRightCommand}" />
        <!-- Ctrl+/: Toggle help -->
        <KeyBinding Key="OemQuestion" Modifiers="Ctrl" Command="{Binding ToggleHelpCommand}" />
    </Window.InputBindings>

    <Grid>
        <!-- Main scrollable content -->
        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{StaticResource BackgroundBrush}"
                      PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel">
            <ItemsControl x:Name="PanelList"
                          ItemsSource="{Binding Panels}"
                          Margin="12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:RowView Margin="0,0,0,12"
                                       TerminalFontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FocusedCellId="{Binding DataContext.FocusedCellId, RelativeSource={RelativeSource AncestorType=Window}}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Help overlay -->
        <controls:HelpOverlay Visibility="{Binding ShowHelp, Converter={StaticResource BoolToVisibility}}" />
    </Grid>
</Window>
